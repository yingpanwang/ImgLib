<Window
    x:Class="ImgLib.UI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="using:ImgLib.UI"
    xmlns:vViews="using:ImgLib.UI.Views"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    xmlns:models="using:ImgLib.UI.Models"
    xmlns:conv="using:ImgLib.UI.Converters"
    Title="ImgLib"
    d:DesignHeight="650"
    d:DesignWidth="800"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">

    <!-- ═══ DataTemplates: ViewModel → View 映射 ═══ -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Menu Bar ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="2,0">
            <Menu>
                <MenuItem Header="菜单">
                    <MenuItem Command="{Binding OpenRootFolderCommand}" Header="打开目录" />
                    <Separator />
                    <MenuItem Command="{Binding OpenWatermarkPresetsCommand}" Header="水印预设" />
                    <Separator />
                    <MenuItem Command="{Binding OpenSettingsCommand}" Header="设置 ⚙" />
                </MenuItem>
                <MenuItem Header="导入">
                    <MenuItem Header="导入图片" />
                    <Separator/>
                    <MenuItem Header="导入水印预设"/>
                </MenuItem>
                <MenuItem Header="导出">
                    <MenuItem Command="{Binding ExportCurrentCommand}" Header="导出当前图片" />
                    <Separator />
                    <MenuItem Command="{Binding ExportBatchCommand}" Header="批量导出" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid x:Name="ContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="0" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="6*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Left: Navigation Bar ═══ -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="2" Margin="4,6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:NavigationItem">
                                <Border
                                    Background="{Binding IsSelected, Converter={x:Static conv:NavConverters.BoolToSelectedBg}}"
                                    CornerRadius="8">
                                    <Button
                                        Command="{Binding $parent[Window].DataContext.NavigateCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        Cursor="Hand"
                                        Padding="4,8"
                                        HorizontalContentAlignment="Center">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover">
                                                <Setter Property="Background" Value="{StaticResource HoverBg}" />
                                            </Style>
                                        </Button.Styles>
                                        <StackPanel Orientation="Vertical"
                                                    HorizontalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="9"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ═══ Left-Middle: Image List ═══ -->
            <Border x:Name="ImageListBorder"
                    Grid.Column="1"
                    Background="{StaticResource SidebarBg}">
                <v:ImgListBoxView DataContext="{Binding ImgListBoxViewModel}" />
            </Border>

            <!-- ═══ Splitter ═══ -->
            <GridSplitter x:Name="ContentSplitter"
                          Grid.Column="2"
                          ResizeDirection="Columns"
                          Background="Transparent" />

            <!-- ═══ Right: Workspace Area ═══ -->
            <Border Grid.Column="3"
                    Background="{StaticResource ContentBg}">
                <ContentControl Content="{Binding ActiveWorkspace}">
                    <ContentControl.DataTemplates>
                        <DataTemplate x:DataType="vm:WatermarkDesignViewModel">
                            <v:WatermarkDesignView />
                        </DataTemplate>
                        <DataTemplate x:DataType="vm:GalleryViewModel">
                            <v:GalleryView />
                        </DataTemplate>
                        <DataTemplate x:DataType="vm:DebugViewModel">
                            <v:DebugView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>

        <!-- ═══ Floating Panels (Right Bottom Corner) ═══ -->
        <Border Grid.Row="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="16"
                Background="{x:Null}">
            <StackPanel Spacing="8">
                <vViews:ExportProgressView DataContext="{Binding ExportProgressViewModel}" />
                <vViews:ToastView DataContext="{Binding ToastViewModel}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
