<Window
x:Class="ImgLib.UI.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:v="using:ImgLib.UI"
xmlns:vm="using:ImgLib.UI.ViewModels"
Title="ImgLib"
d:DesignHeight="650"
d:DesignWidth="800"
x:DataType="vm:MainWindowViewModel"
mc:Ignorable="d">
    <DockPanel>
        <!-- Menu Bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="2,0">
            <Menu>
                <MenuItem Header="菜单">
                    <MenuItem Command="{Binding OpenRootFolderCommand}" Header="打开目录" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="350"></ColumnDefinition>
                <ColumnDefinition Width="1"></ColumnDefinition>
                <ColumnDefinition Width="6*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Left: Image List -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBg}">
                <v:ImgListBoxView DataContext="{Binding ImgListBoxViewModel}" />
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" />

            <!-- Right: Design Area -->
            <DockPanel Grid.Column="2"
                       Background="{StaticResource ContentBg}">
                <v:WatermarkDesignView DataContext="{Binding WatermarkDesignViewModel}" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
