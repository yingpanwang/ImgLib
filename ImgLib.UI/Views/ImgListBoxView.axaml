<UserControl
x:Class="ImgLib.UI.ImgListBoxView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
xmlns:v="using:ImgLib.UI"
xmlns:vm="using:ImgLib.UI.ViewModels"
xmlns:vmd="using:ImgLib.UI.ViewModels.Design"
d:DesignHeight="650"
d:DesignWidth="450"
x:DataType="vm:ImgListBoxViewModel"
mc:Ignorable="d">
	<Design.DataContext>
		<vmd:Design_ImgListBoxViewModel />
	</Design.DataContext>
	<UserControl.Styles>
		<Style Selector="ListBox:empty">
			<Setter Property="Template">
				<ControlTemplate>
					<Border
					Background="{TemplateBinding Background}"
					BorderBrush="{TemplateBinding BorderBrush}"
					BorderThickness="{TemplateBinding BorderThickness}">
						<TextBlock
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						FontStyle="Italic"
						Text="暂无数据" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
	</UserControl.Styles>
	<ListBox
	Name="l"
	ItemsSource="{Binding ImgListItems}"
	SelectedItem="{Binding SelectedImgItem, Mode=TwoWay}">
		<ListBox.ItemTemplate>
			<DataTemplate DataType="vm:ImgListItemViewModel">
				<!--<Border
				Padding="8"
				MinWidth="400"
				BorderBrush="#DDD"
				BorderThickness="1"
				CornerRadius="8"
				Background="White">
					<Grid ColumnDefinitions="120,*" ColumnSpacing="12">

						--><!-- 缩略图 --><!--
						<Border
						Width="120"
						Height="90"
						CornerRadius="6"
						ClipToBounds="True"
						Background="#F0F0F0">

							<Image
							Stretch="UniformToFill"
							Source="{Binding ImageSource^}" />
						</Border>

						--><!-- 信息区 --><!--
						<Grid
						Grid.Column="1"
						ColumnDefinitions="70,Auto"
						RowDefinitions="Auto,Auto,Auto,Auto"
						RowSpacing="4"
						VerticalAlignment="Center"
						>

							--><!-- 名称 --><!--
							<TextBlock Grid.Row="0" Text="名称:" FontWeight="SemiBold"/>
							<TextBlock Grid.Row="0" Grid.Column="1" FontSize="11"
									   Text="{Binding FileName}" VerticalAlignment="Bottom"
									   TextTrimming="CharacterEllipsis"/>

							--><!-- 类型 --><!--
							<TextBlock Grid.Row="1" Text="类型:" FontWeight="SemiBold"/>
							<TextBlock Grid.Row="1" Grid.Column="1" FontSize="11"
									   Text="{Binding FileExtension}"  VerticalAlignment="Bottom"
									   TextTrimming="CharacterEllipsis"/>

							--><!-- 日期 --><!--
							<TextBlock Grid.Row="2" Text="日期:" FontWeight="SemiBold"/>
							<TextBlock Grid.Row="2" Grid.Column="1" FontSize="11"
									   Text="{Binding FileCreationTime}"  VerticalAlignment="Bottom"
									   TextTrimming="CharacterEllipsis"/>
						</Grid>

					</Grid>
				</Border>-->
				<v:ImgListBoxItemViewCompat/>
			</DataTemplate>
		</ListBox.ItemTemplate>
	</ListBox>

</UserControl>
