<UserControl
    x:Class="ImgLib.UI.ImgListBoxView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:v="using:ImgLib.UI"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    xmlns:vmd="using:ImgLib.UI.ViewModels.Design"
    d:DesignHeight="650"
    d:DesignWidth="450"
    x:DataType="vm:ImgListBoxViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vmd:Design_ImgListBoxViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="ListBox:empty">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontStyle="Italic"
                            Text="暂无数据" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>
    <ListBox
        Name="l"
        ItemsSource="{Binding ImgListItems}"
        SelectedItem="{Binding SelectedImgItem, Mode=TwoWay}">
        <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ImgListItemViewModel">
                <Border
                    Margin="2"
                    Padding="4"
                    BorderBrush="LightGray"
                    BorderThickness="1">

                    <Grid ColumnDefinitions="2*,3*">
                        <Image
                            Grid.Column="0"
                            MaxHeight="200"
                            Margin="5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Source="{Binding ImageSource^}" />
                        <Grid
                            Grid.Column="1"
                            Margin="15"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ColumnDefinitions="2*,10*"
                            RowDefinitions="*,*">

                            <RelativePanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2">

                                <Label
                                    Name="l_name"
                                    Width="80"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="文件名称:"
                                    FontWeight="Bold" />

                                <TextBlock
                                    Name="t_name"
                                    Height="25"
                                    MinWidth="150"
                                    HorizontalAlignment="Left"
                                    FontSize="8"
                                    RelativePanel.RightOf="l_name"
                                    Text="{Binding FileName}"
                                    TextDecorations="Underline" />

                                <Label
                                    Name="l_type"
                                    MinWidth="120"
                                    MaxWidth="150"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="类型:"
                                    FontWeight="Bold"
                                    RelativePanel.AlignRightWith="l_name"
                                    RelativePanel.Below="l_name" />

                                <TextBlock
                                    Name="t_type"
                                    RelativePanel.AlignHorizontalCenterWith="t_name"
                                    RelativePanel.Below="t_name"
                                    RelativePanel.RightOf="l_type"
                                    Text="PNG | NEF" />

                                <Label
                                    Name="l_date"
                                    MinWidth="120"
                                    MaxWidth="150"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="拍摄日期:"
                                    FontWeight="Bold"
                                    RelativePanel.AlignRightWith="l_name"
                                    RelativePanel.Below="l_type" />

                                <TextBlock
                                    Name="t_date"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    RelativePanel.AlignLeftWith="t_type"
                                    RelativePanel.AlignVerticalCenterWith="l_date"
                                    RelativePanel.Below="t_type"
                                    Text="2018-09-25" />

                                <Label
                                    Name="l_hasraw"
                                    MinWidth="120"
                                    MaxWidth="150"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="包含Raw文件:"
                                    FontWeight="Bold"
                                    RelativePanel.AlignRightWith="l_name"
                                    RelativePanel.Below="l_date" />

                                <TextBlock
                                    Name="t_hasraw"
                                    RelativePanel.Below="l_date"
                                    RelativePanel.RightOf="t_date"
                                    Text="是" />


                            </RelativePanel>
                        </Grid>
                    </Grid>

                </Border>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

</UserControl>
