<UserControl
    x:Class="ImgLib.UI.WatermarkDesignView"
    Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="using:ImgLib.UI"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    xmlns:paz="using:Avalonia.Controls.PanAndZoom"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:li="using:ImgLib.UI.Behaviors"
    d:DesignHeight="850"
    d:DesignWidth="800"
    x:DataType="vm:WatermarkDesignViewModel"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*,Auto">
        <!-- ═══ Image Preview Area ═══ -->
        <Border Grid.Column="0"
                Background="#FAFAFA"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0"
                Padding="0">
            <Grid Name="PreviewGrid">
                <paz:ZoomBorder
                    EnablePan="True"
                    PanButton="Left"
                    Name="ZoomBorder"
                    Stretch="None"
                    ZoomSpeed="1.2"
                    ClipToBounds="True"
                    Focusable="True"
                    VerticalAlignment="Stretch"
                    EnableGestureRotation="True"
                    IsHitTestVisible="True"
                    HorizontalAlignment="Stretch">
                    <Image
                        Name="PreviewImage"
                        Margin="5,5"
                        Opacity="{Binding PreviewOpacity}"
                        DockPanel.Dock="Top"
                        RenderTransformOrigin="0.5,0.5"
                        Source="{Binding PreviewImageSource}">
                        <Image.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                            </Transitions>
                        </Image.Transitions>
                        <Image.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="重置">
                                    <i:Interaction.Behaviors>
                                        <EventTrigger EventName="Click">
                                            <CallMethodAction MethodName="ResetMatrix" TargetObject="{Binding #ZoomBorder}"/>
                                        </EventTrigger>
                                    </i:Interaction.Behaviors>
                                </MenuItem>
                            </ContextMenu>
                        </Image.ContextMenu>
                        <Image.RenderTransform>
                            <RotateTransform Angle="{Binding PreviewAngle}" />
                        </Image.RenderTransform>
                    </Image>
                    <i:Interaction.Behaviors>
                        <li:ResetOnSourceChangedBehavior Source="{Binding PreviewImageSource}"/>
                    </i:Interaction.Behaviors>
                </paz:ZoomBorder>

                <!-- ═══ 悬浮直方图 (可拖拽) ═══ -->
                <Border
                    Name="HistogramOverlay"
                    IsVisible="{Binding PreviewSettingsViewModel.ShowHistogram}"
                    Background="#E6191919"
                    BorderBrush="#40000000"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Margin="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="200"
                    Height="140"
                    Cursor="Hand"
                    ZIndex="10"
                    PointerPressed="OnHistogramPointerPressed"
                    PointerMoved="OnHistogramPointerMoved"
                    PointerReleased="OnHistogramPointerReleased"
                    PointerCaptureLost="OnHistogramPointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform
                            X="{Binding HistogramTranslateX}"
                            Y="{Binding HistogramTranslateY}" />
                    </Border.RenderTransform>
                    <v:HistogramView DataContext="{Binding HistogramViewModel}" />
                </Border>

                <!-- ═══ 展开/收起设置面板按钮 ═══ -->
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="28"
                    Height="80"
                    Margin="0,0,0,0"
                    Padding="0"
                    Background="#E9060606"
                    BorderBrush="#25000000"
                    BorderThickness="1,0,0,1"
                    CornerRadius="6,0,0,6"
                    Cursor="Hand"
                    Command="{Binding ToggleSettingsPanelCommand}"
                    ToolTip.Tip="切换设置面板"
                    ZIndex="5">
                    <Panel>
                        <TextBlock
                            Text="❮"
                            FontSize="14"
                            Foreground="{StaticResource TextSecondary}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsSettingsPanelExpanded}" />
                        <TextBlock
                            Text="❯"
                            FontSize="14"
                            Foreground="{StaticResource TextSecondary}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsSettingsPanelExpanded, Converter={x:Static BoolConverters.Not}}" />
                    </Panel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Settings Panel (右侧栏，展开时推开预览) ═══ -->
        <Border
            Grid.Column="1"
            IsVisible="{Binding IsSettingsPanelExpanded}"
            Background="{StaticResource PanelBg}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1,0,0,0"
            Padding="5"
            Width="380"
            MinWidth="320"
            MaxWidth="480">
            <ScrollViewer>
                <v:WatermarkSettingsView DataContext="{Binding WatermarkSettingsViewModel}" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
