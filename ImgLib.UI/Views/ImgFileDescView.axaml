<UserControl
    x:Class="ImgLib.UI.ImgFileDescView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    x:DataType="vm:ImgFileDescViewModel"
    mc:Ignorable="d">
    <!--
        图片基础信息展示面板 - 表单形式
        显示文件名、路径、像素尺寸、文件大小等基础信息
    -->
    <Border
        Padding="16,12"
        Background="{StaticResource PanelBg}"
        BorderBrush="{StaticResource BorderSubtle}"
        BorderThickness="0,0,0,1"
        CornerRadius="0">
        <Grid
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            ColumnDefinitions="Auto,Auto,*"
            RowSpacing="6"
            ColumnSpacing="10">

            <!-- ── 标题行：文件名 + 扩展名 ── -->
            <TextBlock
                Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                Text="{Binding FileName}"
                FontWeight="Bold"
                FontSize="14"
                Foreground="{StaticResource TextPrimary}"
                TextTrimming="CharacterEllipsis"
                Margin="0,0,0,4" />

            <!-- ── 分隔线 ── -->
            <Border
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Height="1"
                Background="{StaticResource BorderSubtle}"
                Margin="0,0,0,4" />

            <!-- ── 目录 ── -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="📁"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="目录"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Grid.Row="2" Grid.Column="2"
                       Text="{Binding DirectoryPath}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- ── 像素尺寸 ── -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="🖼"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="3" Grid.Column="1"
                       Text="像素尺寸"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <StackPanel Grid.Row="3" Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock
                    Text="{Binding DimensionDisplay}"
                    FontSize="12"
                    Foreground="{StaticResource TextPrimary}"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{Binding MegapixelDisplay}"
                    FontSize="12"
                    Foreground="{StaticResource TextTertiary}"
                    VerticalAlignment="Center"
                    IsVisible="{Binding MegapixelDisplay, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>

            <!-- ── 文件大小 ── -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="📦"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="4" Grid.Column="1"
                       Text="文件大小"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Grid.Row="4" Grid.Column="2"
                       Text="{Binding FileSize}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- ── 创建时间 ── -->
            <TextBlock Grid.Row="5" Grid.Column="0"
                       Text="📅"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="5" Grid.Column="1"
                       Text="创建时间"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Grid.Row="5" Grid.Column="2"
                       Text="{Binding FileCreationTime}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- ── 修改时间 ── -->
            <TextBlock Grid.Row="6" Grid.Column="0"
                       Text="🕐"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="6" Grid.Column="1"
                       Text="修改时间"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Grid.Row="6" Grid.Column="2"
                       Text="{Binding FileModifiedTime}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</UserControl>
