<UserControl
    x:Class="ImgLib.UI.DebugView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    x:DataType="vm:DebugViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.info-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}" />
            <Setter Property="MinWidth" Value="100" />
        </Style>
        <Style Selector="TextBlock.info-value">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button.link">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.link:pointerover">
            <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Button.link /template/ ContentPresenter#PART_ContentPresenter TextBlock">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="500">
            <TextBlock Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" />

            <Border Height="1" Background="{StaticResource BorderSubtle}" />

            <!-- 系统信息 -->
            <TextBlock Text="系统信息"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" />
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="运行时版本" />
                    <TextBlock Classes="info-value" Text="{Binding RuntimeVersion}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="操作系统" />
                    <TextBlock Classes="info-value" Text="{Binding OSVersion}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="处理器核心数" />
                    <TextBlock Classes="info-value" Text="{Binding ProcessorCount}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="工作目录" />
                    <Button Classes="link"
                            Content="{Binding WorkingDirectory}"
                            Command="{Binding OpenInExplorerCommand}"
                            CommandParameter="{Binding WorkingDirectory}" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{StaticResource BorderSubtle}" />

            <!-- 应用信息 -->
            <TextBlock Text="应用信息"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" />
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="应用版本" />
                    <TextBlock Classes="info-value" Text="{Binding AppVersion}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="SkiaSharp 版本" />
                    <TextBlock Classes="info-value" Text="{Binding SkiaSharpVersion}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="内存占用" />
                    <TextBlock Classes="info-value" Text="{Binding ProcessMemory}" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{StaticResource BorderSubtle}" />

            <!-- 缓存 -->
            <TextBlock Text="缩略图缓存"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" />
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="缓存大小" />
                    <TextBlock Classes="info-value" Text="{Binding ThumbnailCacheSize}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="info-label" Text="缓存目录" />
                    <Button Classes="link"
                            Content="{Binding ThumbnailCacheDir}"
                            Command="{Binding OpenInExplorerCommand}"
                            CommandParameter="{Binding ThumbnailCacheDir}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="secondary"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        FontSize="12"
                        Padding="12,6" />
                <Button Classes="secondary"
                        Content="清空缓存"
                        Command="{Binding ClearThumbnailCacheCommand}"
                        FontSize="12"
                        Padding="12,6" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
