<UserControl
    x:Class="ImgLib.UI.ImgFileDescView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ImgFileDescViewModel"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*,*">
        <Image
            Grid.Column="0"
            MaxHeight="250"
            Margin="25"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Source="{Binding ImageFileSource}" />
        <UniformGrid
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Columns="2"
            Rows="2">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Text="{Binding FileName}" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Text="文件地址:2222" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Text="文件数量:3" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Content="Exif 信息" />

        </UniformGrid>
    </Grid>
</UserControl>
