<UserControl
    x:Class="ImgLib.UI.WatermarkSettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImgLib.UI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:WatermarkSettingsViewModel"
    mc:Ignorable="d">
    <TabControl>
        <TabItem Header="图像设置">
            <Grid RowDefinitions="*,*">
                <Border
                    Grid.Row="0"
                    BorderBrush="LightGray"
                    BorderThickness="1">
                    <UniformGrid Columns="2" DockPanel.Dock="Top">

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="中心缩放比例" />
                        <NumericUpDown
                            Grid.Row="0"
                            Grid.Column="1"
                            Increment="0.05"
                            Maximum="1"
                            Minimum="0.5"
                            Value="{Binding ImageGenerateOption.Scale, Mode=TwoWay}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="圆角" />
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="{Binding ImageGenerateOption.CornerRadius, Mode=TwoWay}" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="虚化Blur值" />
                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="{Binding ImageGenerateOption.BlurSigma}" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Text="阴影偏移值" />
                        <TextBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Text="{Binding ImageGenerateOption.ShadowOffsetX}" />

                        <TextBlock Text="旋转竖拍图片" />
                        <CheckBox Grid.Row="4" Grid.Column="1" />

                    </UniformGrid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="文本设置">
            <Grid ColumnDefinitions="*" RowDefinitions="*,*">
                <Border Grid.Row="0">
                    <TextBox Text="\{\$Tag1.水印信息\}\ \{\$镜头型号\}\" />
                </Border>
                <Border Grid.Row="1">
                    <Button Content="添加参数" />
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
